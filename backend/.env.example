# Supabase
SUPABASE_URL=your_supabase_project_url
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# JWT
JWT_SECRET=change_this_to_a_random_64_char_string

# LLM (at least one required)
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=AIza...

# Razorpay (for payments)
RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=...

# VAPID (for push notifications — generate with: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=...
VAPID_PRIVATE_KEY=...

# Frontend
FRONTEND_URL=https://gita-agent.vercel.app

# Server
PORT=3001
NODE_ENV=production
